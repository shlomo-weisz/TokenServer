# Copy this file to `.env` before running `docker compose up`.
# Docker Compose automatically loads `.env` from this directory.

# SQL Server
TOKENLEARN_DB_NAME=tokenlearn
TOKENLEARN_DB_PASSWORD=ReplaceWithAStrongPassword
TOKENLEARN_DB_ENCRYPT=false
TOKENLEARN_MSSQL_PID=Developer
TOKENLEARN_SQLSERVER_PORT=1433

# ActiveMQ Artemis
TOKENLEARN_ARTEMIS_USER=admin
TOKENLEARN_ARTEMIS_PASSWORD=ReplaceWithAnotherStrongPassword
TOKENLEARN_ARTEMIS_BROKER_PORT=61616
TOKENLEARN_ARTEMIS_WEB_PORT=8161

# Backend
TOKENLEARN_SERVER_PORT=8080
TOKENLEARN_JWT_SECRET=ReplaceWithALongRandomBase64OrHighEntropySecret
TOKENLEARN_JWT_EXPIRATION=86400000
TOKENLEARN_GOOGLE_CLIENT_ID=
TOKENLEARN_FLYWAY_ENABLED=true

# Course catalog mount
TOKENLEARN_COURSE_CATALOG_HOST_PATH=../openu_all_courses.json
TOKENLEARN_COURSE_CATALOG_CONTAINER_PATH=/app/openu_all_courses.json
